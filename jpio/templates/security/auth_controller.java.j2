package {{ base_package }}.controller;

import {{ base_package }}.dto.request.LoginRequestDTO;
import {{ base_package }}.dto.request.RegisterRequestDTO;
import {{ base_package }}.dto.response.AuthResponseDTO;
import {{ base_package }}.models.entity.{{ user_entity }};
{% if generate_user %}
import {{ base_package }}.models.enum.Role;
{% endif %}
import {{ base_package }}.repository.{{ user_repository }};
import {{ base_package }}.security.JwtUtil;
import lombok.RequiredArgsConstructor;
import org.springframework.http.ResponseEntity;
import org.springframework.security.authentication.AuthenticationManager;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
@RequestMapping("/auth")
{% if pom_features.has_lombok %}
@RequiredArgsConstructor
{% endif %}
public class AuthController {

    private final {{ user_repository }} {{ user_repo_var }};
    private final PasswordEncoder passwordEncoder;
    private final JwtUtil jwtUtil;
    private final AuthenticationManager authenticationManager;

{% if not pom_features.has_lombok %}
    public AuthController({{ user_repository }} {{ user_repo_var }}, PasswordEncoder passwordEncoder, JwtUtil jwtUtil, AuthenticationManager authenticationManager) {
        this.{{ user_repo_var }} = {{ user_repo_var }};
        this.passwordEncoder = passwordEncoder;
        this.jwtUtil = jwtUtil;
        this.authenticationManager = authenticationManager;
    }
{% endif %}

    @PostMapping("/register")
    public ResponseEntity<AuthResponseDTO> register(@RequestBody RegisterRequestDTO request) {
        {{ user_entity }} user = {{ user_entity }}.builder()
                .{{ security_config.username_field }}(request.get{{ username_field_capitalized }}())
                .password(passwordEncoder.encode(request.getPassword()))
{% if generate_user %}
                .role(Role.USER)
{% endif %}
{% for field in security_config.extra_user_fields %}
                .{{ field.name }}(request.get{{ field.capitalized }}())
{% endfor %}
                .build();

        {{ user_repo_var }}.save(user);
        String token = jwtUtil.generateToken(user);
        return ResponseEntity.ok(new AuthResponseDTO(token, user.get{{ username_field_capitalized }}()));
    }

    @PostMapping("/login")
    public ResponseEntity<AuthResponseDTO> login(@RequestBody LoginRequestDTO request) {
        authenticationManager.authenticate(
                new UsernamePasswordAuthenticationToken(
                        request.get{{ username_field_capitalized }}(),
                        request.getPassword()
                )
        );

        {{ user_entity }} user = {{ user_repo_var }}.findBy{{ username_field_capitalized }}(request.get{{ username_field_capitalized }}())
                .orElseThrow();
        String token = jwtUtil.generateToken(user);
        return ResponseEntity.ok(new AuthResponseDTO(token, user.get{{ username_field_capitalized }}()));
    }
}
