package {{ base_package }}.mapper;

import {{ base_package }}.dto.{{ entity_name }}DTO;
import {{ base_package }}.entity.{{ entity_name }};
{% for relation in relations %}
import {{ base_package }}.entity.{{ relation.target }};
{% endfor %}
import org.springframework.stereotype.Component;

import java.util.List;
import java.util.stream.Collectors;

@Component
public class {{ entity_name }}Mapper {

    // ── Entity → DTO ────────────────────────────────────────────────────────

    public {{ entity_name }}DTO toDTO({{ entity_name }} entity) {
        if (entity == null) return null;

        return {{ entity_name }}DTO.builder()
                .id(entity.getId())
{% for field in fields %}
                .{{ field.name }}(entity.get{{ field.capitalized }}())
{% endfor %}
{% for relation in relations %}
    {% if relation.kind in ("OneToMany", "ManyToMany") %}
                .{{ relation.field_name }}Ids(
                    entity.get{{ relation.field_name | capitalize }}() != null
                        ? entity.get{{ relation.field_name | capitalize }}().stream()
                              .map({{ relation.target }}::getId)
                              .collect(Collectors.toList())
                        : List.of()
                )
    {% elif relation.kind == "ManyToOne" %}
                .{{ relation.target_lower }}Id(
                    entity.get{{ relation.target }}() != null
                        ? entity.get{{ relation.target }}().getId()
                        : null
                )
    {% endif %}
{% endfor %}
                .build();
    }

    // ── DTO → Entity ────────────────────────────────────────────────────────

    public {{ entity_name }} toEntity({{ entity_name }}DTO dto) {
        if (dto == null) return null;

        return {{ entity_name }}.builder()
                .id(dto.getId())
{% for field in fields %}
                .{{ field.name }}(dto.get{{ field.capitalized }}())
{% endfor %}
                .build();
        // Note : les relations sont gérées dans le Service
        // pour éviter les dépendances circulaires entre Mappers.
    }

    // ── Liste Entity → Liste DTO ─────────────────────────────────────────────

    public List<{{ entity_name }}DTO> toDTOList(List<{{ entity_name }}> entities) {
        if (entities == null) return List.of();
        return entities.stream()
                .map(this::toDTO)
                .collect(Collectors.toList());
    }
}
