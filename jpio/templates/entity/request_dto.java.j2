package {{ base_package }}.dto.request;

{% if pom_features.has_lombok %}
import lombok.*;
{% endif %}
{% if pom_features.has_validation %}
import jakarta.validation.constraints.*;
{% endif %}
{% for import in extra_imports %}
import {{ import }};
{% endfor %}
{% for field in fields %}
    {% if field.is_enum %}
import {{ base_package }}.models.enum.{{ field.java_type }};
    {% endif %}
{% endfor %}
{% for relation in relations %}
import java.util.List;
{% endfor %}

{% if pom_features.has_lombok %}
@Data
@NoArgsConstructor
@AllArgsConstructor
@Builder
{% endif %}
public class {{ entity_name }}RequestDTO {

{% for field in fields %}
    {% if pom_features.has_validation and not field.nullable %}
        {% if field.java_type == "String" %}
    @NotBlank
        {% else %}
    @NotNull
        {% endif %}
    {% endif %}
    private {{ field.java_type }} {{ field.name }};
{% endfor %}
{% for relation in relations %}
    {% if relation.kind in ("OneToMany", "ManyToMany") %}
    private List<Long> {{ relation.field_name }}Ids;
    {% elif relation.kind == "ManyToOne" %}
    private Long {{ relation.target_lower }}Id;
    {% endif %}
{% endfor %}

{% if not pom_features.has_lombok %}
    // ── Getters & Setters ────────────────────────────────────────────────────

{% for field in fields %}
    public {{ field.java_type }} get{{ field.capitalized }}() { return {{ field.name }}; }
    public void set{{ field.capitalized }}({{ field.java_type }} {{ field.name }}) { this.{{ field.name }} = {{ field.name }}; }
{% endfor %}

{% for relation in relations %}
    {% if relation.kind in ("OneToMany", "ManyToMany") %}
    public List<Long> get{{ relation.field_name | capitalize }}Ids() { return {{ relation.field_name }}Ids; }
    public void set{{ relation.field_name | capitalize }}Ids(List<Long> ids) { this.{{ relation.field_name }}Ids = ids; }
    {% else %}
    public Long get{{ relation.target }}Id() { return {{ relation.target_lower }}Id; }
    public void set{{ relation.target }}Id(Long id) { this.{{ relation.target_lower }}Id = id; }
    {% endif %}
{% endfor %}
{% endif %}
}
