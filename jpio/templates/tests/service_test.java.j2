package {{ tc.package_name }};

{% for imp in tc.imports_needed %}
import {{ imp }};
{% endfor %}

@ExtendWith(MockitoExtension.class)
class {{ tc.test_class_name }} {

{% for mock in tc.mock_fields %}
    @Mock
    private {{ mock.type }} {{ mock.name }};
{% endfor %}

    @InjectMocks
    private {{ tc.inject_mocks_type }} {{ tc.inject_mocks_field }};

{% for data in tc.setup_data %}
    private {{ data.type }} {{ data.variable_name }};
{% endfor %}

    @BeforeEach
    void setUp() {
{% for data in tc.setup_data %}
        {{ data.variable_name }} = {{ data.type }}.builder()
{% for field_name, field_value in data.builder_fields %}
                .{{ field_name }}({{ field_value }})
{% endfor %}
                .build();
{% endfor %}
    }

{% for method in tc.test_methods %}
    // ── {{ method.method_under_test }} — {{ method.scenario }} ──

    @Test
    void {{ method.test_name }}() {
{% for mock_line in method.given_mocks %}
        {{ mock_line }}
{% endfor %}

        {{ method.act_line }}

{% for assert_line in method.assert_lines %}
        {{ assert_line }}
{% endfor %}
{% for verify_line in method.verify_lines %}
        {{ verify_line }}
{% endfor %}
    }

{% endfor %}
}
